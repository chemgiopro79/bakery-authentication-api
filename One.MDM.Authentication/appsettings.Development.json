{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "this_is_a_super_secret_key_1234567890",
    "Issuer": "bakery-app",
    "Audience": "myapi"
  },
  "ConnectionStrings": {
    // Nếu bạn chạy PostgreSQL bằng Docker Compose, dùng tên service "postgres"
    //"DefaultConnection": "Host=postgres;Port=5432;Database=bakery_db;Username=postgres;Password=postgres"
    // Nếu PostgreSQL chạy ngoài container, thay bằng:
    "DefaultConnection": "Host=host.docker.internal;Port=5433;Database=bakery_db;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5079"
      }
    }
  }
}
